.values-index
  .page-header.clearfix
    %h1.pull-left= t('.title')
    - if @unrated_images.any?
      = link_to t('.add_rating'), new_value_path, class: 'btn btn-primary pull-right'

  - if @unrated_images.any?
    .panel.panel-default
      .panel-heading
        %h3.panel-title= t('.unrated_images_title')
      .panel-body
        %ul.list-unstyled.unrated-list
          - @unrated_images.each do |image|
            %li
              %span= "#{image.name} (#{image.theme&.name})"
              = link_to t('.add_for_image'), new_value_path(image_id: image.id), class: 'btn btn-sm btn-success'

  %table.table.table-striped.table-bordered
    %thead
      %tr
        %th= t('.image')
        %th= t('.your_rating')
        %th= t('.total_ratings')
        %th= t('.average')
        %th= t('.actions')
    %tbody
      - @values.each do |value|
        %tr
          %td= value.image.name
          %td= value.value
          %td= value.image.values.size
          %td= value_image_average(value)
          %td.actions-cell
            = link_to t('.edit'), edit_value_path(value), class: 'btn btn-sm btn-default'
            = link_to t('.destroy'), value_path(value), method: :delete, data: { confirm: t('.confirm_destroy') }, class: 'btn btn-sm btn-danger'

  - if @values.empty?
    %p.alert.alert-info= t('.empty')

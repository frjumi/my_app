var valuesQty = '<%= @image_data[:values_qty] %>';
$('.total_values_count').text(valuesQty);
$('.theme_values_count').text('<%= @image_data[:theme_values_count] || 0 %>');

var selectedTheme = '<%= j @image_data[:theme] %>';
var emptyTheme = '<%= j t("work.index.select_theme") %>';
var isIdle = <%= @image_data[:idle] ? 'true' : 'false' %>;

if (isIdle || selectedTheme === emptyTheme || selectedTheme === '') {
  $('#work-area').addClass('work-idle');
  $('.img-left-side, .img-right-side').hide();
  $('.image_rating').hide();
  $('.image-kaminari-nav').hide();
  $('.work-ai-facts').hide();
  $('.welcome-title').show();
  $('.image-title').hide().text('');
  $('.image_display h2.up-theme').text(selectedTheme);

  var placeholderUrl = $('#work-area').data('placeholder-url');
  $('.img-center img').off('error.workImage').attr({
    src: placeholderUrl,
    alt: '<%= j t("work.index.welcome_title") %>',
    title: '<%= j t("work.index.welcome_title") %>'
  });

  if (window.WorkNav) {
    window.WorkNav.setContext({ currentPage: 1, themeId: null, totalPages: 0, firstPage: true, lastPage: true, imageId: null });
  }
  if (window.WorkAiFacts) {
    window.WorkAiFacts.updateState(null);
  }
} else {
  $('#work-area').removeClass('work-idle');
  var totalPages = <%= @image_data[:total_pages] || 0 %>;
  var hasImages = totalPages > 0 && <%= @image_data[:image_id].present? ? 'true' : 'false' %>;

  if (hasImages) {
    $('.img-left-side, .img-right-side').show();
    $('.image_rating').show();
    $('.image-kaminari-nav').show();
    $('.work-ai-facts').show();
  } else {
    $('.img-left-side, .img-right-side').hide();
    $('.image_rating').hide();
    $('.image-kaminari-nav').hide();
    $('.work-ai-facts').hide();
  }
  $('.welcome-title').hide();
  $('.image-title').show().text('<%= j @image_data[:name] %>');
  $('.image_display h2.up-theme').text(selectedTheme);

  var pathImage = "<%= asset_path('pictures/' + @image_data[:file]) %>";
  var placeholderUrl = "<%= asset_path('pictures/' + WorkImage::PLACEHOLDER_FILE) %>";
  var $img = $('.img-center img');

  $img.off('error.workImage').on('error.workImage', function() {
    $(this).attr('src', placeholderUrl);
  });
  $img.attr({
    alt: '<%= j @image_data[:name] %>',
    src: pathImage,
    title: '<%= j @image_data[:name] %>'
  });

  var themeId = <%= @image_data[:theme_id] || 'null' %>;
  var currentPage = <%= @image_data[:page] || 1 %>;
  var imageId = <%= @image_data[:image_id].present? ? @image_data[:image_id] : 'null' %>;

  if (window.WorkNav) {
    window.WorkNav.setContext({
      currentPage: currentPage,
      themeId: themeId,
      totalPages: totalPages,
      firstPage: <%= @image_data[:first_page] ? 'true' : 'false' %>,
      lastPage: <%= @image_data[:last_page] ? 'true' : 'false' %>,
      imageId: imageId
    });
  }

  if (window.WorkRating) {
    window.WorkRating.applyRatingState({
      image_id: imageId,
      common_ave_value: <%= @image_data[:common_ave_value].to_f %>,
      new_average: <%= @image_data[:common_ave_value].to_f %>,
      image_values_count: <%= @image_data[:image_values_count] || 0 %>,
      new_total_values: <%= @image_data[:image_values_count] || 0 %>,
      theme_values_count: <%= @image_data[:theme_values_count] || 0 %>,
      user_valued: <%= @image_data[:user_valued].to_i %>,
      user_value: <%= @image_data[:value].to_i %>,
      value: <%= @image_data[:value].to_i %>
    });
  }

  if (window.WorkAiFacts) {
    window.WorkAiFacts.updateState(<%= @image_data[:ai_fact].present? ? raw(@image_data[:ai_fact].to_json) : 'null' %>);
  }
}

$('.select_theme').empty().html("<%= j render 'work/button_theme_select' %>");
$('.rating_message').hide();

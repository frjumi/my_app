var valuesQty = '<%= @image_data[:values_qty] %>';
$('.total_values_count').text(valuesQty);

var selectedTheme = '<%= j @image_data[:theme] %>';
var emptyTheme = '<%= j t("work.index.select_theme") %>';

if (selectedTheme === emptyTheme || selectedTheme === '') {
  $('.img-left-side').hide();
  $('.img-right-side').hide();
  $('.image_rating').hide();
} else {
  $('.img-left-side').show();
  $('.img-right-side').show();
  $('.image_rating').show();
}

$('.image_display h2.up-theme').text(selectedTheme);
$('.select_theme').empty().html("<%= j render 'work/button_theme_select' %>");

var oneImageName = '<%= j @image_data[:name] %>';
var pathImage = "<%= asset_path('pictures/' + @image_data[:file]) %>";
var placeholderUrl = "<%= asset_path('pictures/' + WorkImage::PLACEHOLDER_FILE) %>";

$('.image_display h2.up').text(oneImageName);

var $img = $('.img-center img');
$img.off('error.workImage').on('error.workImage', function() {
  $(this).attr('src', placeholderUrl);
});
$img.attr({ alt: oneImageName, src: pathImage, title: oneImageName });

window.imageCurrentIndex = <%= @image_data[:index] || 0 %>;
window.selectedThemeId   = <%= @image_data[:theme_id] || 0 %>;
window.themeImagesSize   = <%= @image_data[:images_arr_size] || 0 %>;
window.currentImageId    = <%= @image_data[:image_id].present? ? @image_data[:image_id] : 'null' %>;

$('.common_ave_value').text('<%= @image_data[:common_ave_value].to_f > 0 ? sprintf("%.2f", @image_data[:common_ave_value].to_f) : "—" %>');

$('.rating-star').prop('checked', false);
<% if @image_data[:user_valued].to_i == 1 && @image_data[:value].to_i > 0 %>
$('.rating-star[value="<%= @image_data[:value] %>"]').prop('checked', true);
<% end %>

$('.rating_message').hide();

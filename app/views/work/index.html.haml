%h1 Work#index
%p Find me in app/views/work/index.html.haml

.image
  .row
    .col-md-3
      .left_controls
        .select_theme
          = render 'work/button_theme_select', locale: @current_locale
        .total_values
          = t('.total_estimates') + " #{@values_qty}"
    .col-md-9
      .image_display
        .row.image
          .col-md-12
            %h2.up-theme{title: "theme_name"} = @selected_theme
          .col-md-12
            %h2.up{title: "Image file name"} = @selected_image_name
        .row
          .col-md-1.img-left-side
            %h3{title: "list to previous image"}
              %i.fa.fa-chevron-circle-left.strong
          .col-md-10.img-center
            %img{alt: "Default Image", src: asset_path('pictures/Винкс.jpeg'), title: "Default image", style: "width:100%; height:100%;"}
          .col-md-1.img-right-side
            %h3{title: "list to next image"}
              %i.fa.fa-chevron-circle-right.strong
        .image_user_value{title: "Expert value"}
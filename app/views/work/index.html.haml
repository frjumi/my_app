#work-area.work-page.work-idle{data: { placeholder_url: asset_path("pictures/#{WorkImage::PLACEHOLDER_FILE}"), select_theme_first: t('.select_theme_first'), navigation_error: t('.navigation_error'), rating_error: t('.rating_error'), facts_error: t('.facts_error'), submit_rating: t('.submit_rating'), select_rating_hint: t('.select_rating_hint'), facts_button: t('.facts_button'), facts_loading: t('.facts_loading') }}
  .row.work-layout
    .col-md-3.col-sm-12.work-sidebar
      .left_controls.panel-card
        .select_theme-wrapper
          .select_theme
            = render 'work/button_theme_select', locale: @current_locale
        .work-stats
          .stat-item.total_values
            = t('.total_estimates')
            %span.total_values_count= @values_qty
          .stat-item.theme_values
            = t('.theme_ratings_count')
            %span.theme_values_count= @theme_values_count
    .col-md-9.col-sm-12.work-content
      .image_display.panel-card
        .row.image-header
          .col-md-12
            %h2.up-theme= @selected_theme
          .col-md-12
            %h2.welcome-title= t('.welcome_title')
            %h2.image-title{style: 'display: none;'}
        .row.image-viewer
          .col-md-1.img-left-side.nav-disabled
            %button.nav-arrow.btn-nav{type: 'button', title: t('.prev_image')}
              %i.fa.fa-chevron-circle-left
          .col-md-10.img-center
            %img.work-image{alt: t('.welcome_title'), src: asset_path("pictures/#{WorkImage::PLACEHOLDER_FILE}"), title: t('.welcome_title')}
          .col-md-1.img-right-side.nav-disabled
            %button.nav-arrow.btn-nav{type: 'button', title: t('.next_image')}
              %i.fa.fa-chevron-circle-right
        .row
          .col-md-12.image-kaminari-nav.text-center{style: 'display: none;'}
            %span.kaminari-pagination-label= t('.pagination_label')
            %strong.page-current 1
            = t('.pagination_of')
            %strong.page-total 0
        .work-ai-facts{style: 'display: none;'}
          .row
            .col-md-12
              %h3.ai-facts-title= t('.facts_title')
              %p.ai-fact-text{style: 'display: none;'}
              %button#load-ai-facts.btn.btn-info{type: 'button', style: 'display: none;'}= t('.facts_button')
        .image_rating
          .row
            .col-md-12.rating-stats
              %span.average_rating
                %strong= t('.average_rating')
                %span.common_ave_value —
              %span.image_values_count_wrap
                %strong= t('.ratings_count')
                %span.image_values_count 0
          .row
            .col-md-12
              %p.rating-label= t('.your_rating')
              .rating-stars{role: 'radiogroup', 'aria-label': t('.your_rating')}
                - (1..5).each do |star|
                  %button.star-btn{type: 'button', 'data-value': star, title: star}
                    %i.fa.fa-star-o
          .row
            .col-md-12.rating-actions
              %button#submit-rating.btn.btn-primary{type: 'button', disabled: true}= t('.select_rating_hint')
          .row
            .col-md-12
              .rating_message.alert{style: 'display:none;'}

// Показать форму выбора темы в боковой панели (не перекрывает изображение)
$('.img-left-side, .img-right-side').hide();
$('.select_theme').empty().html("<%= j render 'work/choose_theme_from_arr' %>");

$(document).off('click.workThemeSelect').on('click.workThemeSelect', function(e) {
  if ($(e.target).closest('.select_theme-wrapper').length) {
    return;
  }
  $('.form_select').hide();
  $('.select_theme').empty().html("<%= j render 'work/button_theme_select' %>");
});

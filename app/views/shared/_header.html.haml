%header.navbar.navbar-default.navbar-fixed-top
  .container
    .navbar-header
      = link_to "My App", root_path, class: "navbar-brand"
    %ul.nav.navbar-nav
      %li= link_to "Home", root_path
      %li= link_to "Help", main_help_path
      %li= link_to "Contacts", main_contacts_path
      %li= link_to "About", main_about_path
      %li= link_to 'Images', images_path
      %li= link_to 'Themes', themes_path
      %li= link_to 'Values', values_path
    %ul.nav.navbar-nav.pull-right
      - if signed_in?
        %li
          = link_to current_user.name, current_user
        %li
          = link_to "Sign out", signout_path, method: :delete
      - else
        %li= link_to "Sign in", signin_path
        %li= link_to "Sign up", signup_path